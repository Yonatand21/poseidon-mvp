# POSEIDON MVP - Docker Compose environment overrides.
# Copy to .env for local dev. .env is gitignored.

# Which compose profiles to enable. Comma-separated.
# Options: core, ai, viz
# Defaults to `core` which brings up the mission-essential stack only.
COMPOSE_PROFILES=core

# ROS 2 domain id (keep unique per dev workstation on shared networks).
ROS_DOMAIN_ID=42

# Target scenario file (relative to repo root).
POSEIDON_SCENARIO=scenarios/hero_choke_point_gnss_denied.yaml

# AI mode: on | off | shadow
POSEIDON_AI_MODE=off

# Image registry and tag.
# Defaults pull from GHCR. Override to `` (empty) plus POSEIDON_IMAGE_TAG=local
# to use locally-built images when iterating on the Dockerfiles.
POSEIDON_IMAGE_REGISTRY=ghcr.io/yonatand21/poseidon-mvp
POSEIDON_IMAGE_TAG=dev

# NVIDIA GPU visibility - only consumed by the docker-compose.gpu.yml
# overlay on Linux hosts with the NVIDIA Container Toolkit installed.
NVIDIA_VISIBLE_DEVICES=all
