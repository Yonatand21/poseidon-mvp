Build/
DerivedDataCache/
Intermediate/
Saved/
*.VC.db
*.opensdf
*.sdf
*.sln
*.suo
*.xcodeproj/
*.xcworkspace/

# Local user overrides
Config/DefaultEditorPerProjectUserSettings.ini
Config/*_LOCAL_USER.ini

# Platform-specific
.DS_Store
Thumbs.db
